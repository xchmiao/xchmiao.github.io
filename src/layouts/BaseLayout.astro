---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Technical notes, working lessons, and occasional loose thoughts.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="site-title" href="/">Xiaochang Miao</a>
        <nav class="site-nav" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/posts/">Posts</a>
          <a href="/about/">About</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>Built with Astro. Written in Markdown.</p>
      </footer>
    </div>
  </body>
</html>
