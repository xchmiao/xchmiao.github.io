---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BaseLayout title={`${post.data.title} | Xiaochang Miao`} description={post.data.description}>
  <article class="post">
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <p class="post-date-pill">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
      </p>
      <p class="post-description">{post.data.description}</p>
      {post.data.heroImage && (
        <figure class="post-hero-figure">
          <img
            class="post-hero-image"
            src={post.data.heroImage}
            alt={post.data.heroImageAlt ?? ""}
          />
        </figure>
      )}
    </header>
    {headings.length > 0 && (
      <details class="post-toc">
        <summary class="post-toc-title">Table of Contents</summary>
        <nav aria-label="Table of contents">
          <ul>
            {headings
              .filter((heading) => heading.depth <= 3)
              .map((heading) => (
                <li class={`toc-depth-${heading.depth}`}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
          </ul>
        </nav>
      </details>
    )}
    <div class="post-body">
      <Content />
    </div>
  </article>
</BaseLayout>
