---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About | Xiaochang Miao"
  description="About this blog and the kinds of technical notes published here."
>
  <section class="page-intro">
    <h1>About</h1>
    <p class="hero-copy">
      I work on machine learning systems and keep returning to ideas that make complex things feel less arbitrary.
    </p>
    <p class="hero-copy about-link-row">
      <a
        class="about-social-link"
        href="https://www.linkedin.com/in/xiaochang-miao-61865067"
        target="_blank"
        rel="noreferrer"
        aria-label="Xiaochang Miao on LinkedIn"
      >
        <svg
          class="about-social-icon"
          viewBox="0 0 24 24"
          aria-hidden="true"
          focusable="false"
        >
          <rect x="2" y="2" width="20" height="20" rx="3" fill="currentColor" />
          <path
            fill="#ffffff"
            d="M8.34 9.41A1.41 1.41 0 1 1 8.34 6.59a1.41 1.41 0 0 1 0 2.82ZM9.75 10.77H6.93v7.8h2.82v-7.8Zm4.5 0h-2.8v7.8h2.8v-4.1c0-2.28 2.95-2.46 2.95 0v4.1H20v-5.08c0-3.95-4.53-3.81-5.75-1.85v-.87Z"
          />
        </svg>
      </a>
    </p>
  </section>
</BaseLayout>
